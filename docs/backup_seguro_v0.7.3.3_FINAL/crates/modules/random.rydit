# random module - numeros aleatorios
# v0.1.6 - Shield Project
# PRNG xorshift - sin dependencias externas

# int(min, max) -> numero entero aleatorio en [min, max]
rytmo int(min, max) {
    return __random_int(min, max)
}

# float() -> numero flotante aleatorio en [0.0, 1.0)
rytmo float() {
    return __random_float()
}

# choice(array) -> elemento aleatorio del array
rytmo choice(array) {
    return __random_choice(array)
}
