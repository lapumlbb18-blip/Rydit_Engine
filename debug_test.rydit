shield.init
dark.slot frame = 0
dark.slot x = 400
dark.slot y = 300
dark.slot velocidad = 5

ryda frame < 200 {
    # Fondo
    draw.rect(0, 0, 800, 600, "negro")
    
    # Dibujar jugador
    draw.circle(x, y, 30, "azul")
    
    # Lógica de movimiento
    x = x + velocidad
    onif x > 750 {
        velocidad = -velocidad
        voz "Rebotó en pared derecha"
    }
    onif x < 50 {
        velocidad = -velocidad
        voz "Rebotó en pared izquierda"
    }
    
    # Debug en pantalla
    draw.text("Frame: " + frame, 10, 10, 20, "blanco")
    draw.text("x: " + x, 10, 40, 20, "verde")
    draw.text("vel: " + velocidad, 10, 70, 20, "amarillo")
    
    # Salir con escape
    onif tecla_presionada("escape") {
        break
    }
    
    dark.slot frame = frame + 1
}

voz "Finalizó - Frames: " + frame
