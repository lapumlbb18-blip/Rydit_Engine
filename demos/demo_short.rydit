shield.init
dark.slot f = 0
ryda f < 500 {
    dark.slot f = f + 1
    draw.rect(0, 0, 800, 600, "negro")
    draw.text("Demo RyDit", 300, 100, "amarillo")
    draw.circle(400, 300, 50, "rojo")
    draw.circle(400, 300, 40, "verde")
    draw.circle(400, 300, 30, "azul")
    draw.rect(100, 400, 60, 60, "naranja")
    draw.rect(200, 400, 60, 60, "violeta")
    draw.line(50, 50, 200, 50, "blanco")
    draw.line(50, 70, 200, 70, "cyan")
    draw.text("Frame: " + f, 10, 570, "gris")
